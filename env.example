# Core LLM settings (Ollama-First Local Setup)
MODEL_PROVIDER=ollama
MODEL_NAMES=["llama3.2"]
MODEL_BASE_URL=http://localhost:11434
EMBEDDINGS_MODEL_NAME=nomic-embed-text
EMBEDDINGS_BASE_URL=http://localhost:11434

# External Tool API Keys (Optional)
TAVILY_API_KEY=
OPENAI_API_KEY=

# Authentication and JWT Token Setup
TOKEN_BEARER_URL=/api/v1/auth/login
JWT_SECRET=f7410f8d0107749f066a06b360288d1d92bc8f9c23e3326d069793743d4992f2
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRY_MINS=1500
REFRESH_TOKEN_EXPIRY_DAYS=1

# PostgreSQL + pgvector Storage
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=test
POSTGRES_DATABASE=langgraph_db
PGVECTOR_COLLECTION_NAME=my_collection

# Memory RAG Cognitive Settings (Chapters 4, 6, 7, 10, 14)
MEMORY_DECAY_RATE=0.05
MEMORY_MAX_AGE_DAYS=30
MEMORY_CONSOLIDATION_INTERVAL=10
MEMORY_IMPORTANCE_THRESHOLD=0.3

# Frontend Lab Suite config
BACKEND_BASE_URL=http://127.0.0.1:8000/api/v1

# --- Guardrails (see backend/app/guardrails/config.py) ---
GUARD_INJECTION_THRESHOLD=0.8
GUARD_TOXICITY_THRESHOLD=0.8
GUARD_MAX_INPUT_CHARS=4000
GUARD_TOPIC_MIN_COSINE=0.72
GUARD_DOC_MIN_COSINE=0.65
GUARD_GROUNDING_MIN=0.7
GUARD_DEDUP_MAX_COSINE=0.95
GUARD_MAX_RETRIES=2
GUARD_SESSION_TOKEN_CAP=20000
GUARD_TENANT_DAILY_TOKEN_CAP=500000
GUARD_RATE_LIMIT_RPM=30
GUARD_EXPENSIVE_CMD_DAILY_CAP=20
GUARD_BREAKER_FAILURES=5
GUARD_BREAKER_RESET_SECONDS=30
GUARD_OLLAMA_TIMEOUT_SECONDS=20
GUARD_JUDGE_MODEL=llama3.1
GUARD_CLASSIFIER_MODEL=llama3.2:1b
